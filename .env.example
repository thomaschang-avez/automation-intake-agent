# ── Asana ─────────────────────────────────────────────────────────
ASANA_TOKEN=your-asana-personal-access-token
ASANA_PROJECT_ID=your-asana-project-gid
ASANA_WORKSPACE_ID=your-asana-workspace-gid

# Custom field GIDs (from your Asana project settings)
ASANA_FIELD_REQUEST_TYPE=your-request-type-field-gid
ASANA_FIELD_PRIORITY=your-priority-field-gid
ASANA_FIELD_REQUESTOR=your-requestor-field-gid

# Request Type enum option GIDs
ASANA_OPT_NEW_AUTOMATION=your-new-automation-option-gid
ASANA_OPT_IMPROVEMENT=your-improvement-option-gid
ASANA_OPT_RESEARCH=your-research-option-gid
ASANA_OPT_ENGINEERING=your-engineering-option-gid
ASANA_OPT_OPERATIONS=your-operations-option-gid
ASANA_OPT_DATA_SOURCE=your-data-source-option-gid

# Priority enum option GIDs
ASANA_OPT_TIER1=your-tier1-option-gid
ASANA_OPT_TIER2=your-tier2-option-gid
ASANA_OPT_TIER3=your-tier3-option-gid

# ── Google Cloud / Vertex AI ──────────────────────────────────────
GEMINI_PROJECT=your-gcp-project-id
GEMINI_LOCATION=us-central1

# Service account JSON (base64-encoded) for Vertex AI auth
GCP_SERVICE_ACCOUNT=base64-encoded-service-account-json

# ── Server ────────────────────────────────────────────────────────
PORT=8080
